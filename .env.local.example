# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 환경 변수 설정
# .env.local로 복사하여 실제 값을 입력한세요
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ─────────────────────────────────────────────────────
# Supabase 설정
# 주의: NEXT_PUBLIC_* 변수는 브라우저에 노출됩니다
# ─────────────────────────────────────────────────────

# Supabase 프로젝트 URL
NEXT_PUBLIC_SUPABASE_URL=https://xbjgdsyukjdkfvcbzmjc.supabase.co

# Supabase Anonymous Key (브라우저에서 사용, RLS로 보호됨)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase Service Role Key (서버에서만 사용, RLS 우회)
# 절대 브라우저에 노출하지 마세요!
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─────────────────────────────────────────────────────
# 관리자 인증 (L-sec89 이후 필수 — env 이관 완료)
# ─────────────────────────────────────────────────────

# 관리자 마스터 패스워드 (최소 6자)
# 모든 환경(prod/preview/local) 공통 필수. 미설정 시 admin API 전면 차단.
# 과거 `ADMIN_TOKEN=wishes2026` 은 L-sec3/sec89 에서 제거됨 (Vercel env 에서도 삭제 가능).
WISHES_ADMIN_MASTER_PASSWORD=your_admin_master_password_here

# ─────────────────────────────────────────────────────
# 선택사항 (크롤러 브리지)
# ─────────────────────────────────────────────────────

# 크롤러 스크립트 전용 Bearer 토큰 (최소 16자).
# 설정하지 않으면 크롤러 경로 비활성화. 마스터 패스워드와 분리 운영 권장.
# WISHES_CRAWLER_BRIDGE_TOKEN=your_crawler_bridge_token_here

# ─────────────────────────────────────────────────────
# 선택사항: JWT / 세션 쿠키 시크릿
# ─────────────────────────────────────────────────────

# HttpOnly 세션 쿠키(ws_session) 서명용 시크릿 (C-2 phase 1 이후)
# ADMIN_JWT_SECRET=your_jwt_secret_here
