# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 환경 변수 설정
# .env.local로 복사하여 실제 값을 입력한세요
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ─────────────────────────────────────────────────────
# Supabase 설정
# 주의: NEXT_PUBLIC_* 변수는 브라우저에 노출됩니다
# ─────────────────────────────────────────────────────

# Supabase 프로젝트 URL
NEXT_PUBLIC_SUPABASE_URL=https://xbjgdsyukjdkfvcbzmjc.supabase.co

# Supabase Anonymous Key (브라우저에서 사용, RLS로 보호됨)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase Service Role Key (서버에서만 사용, RLS 우회)
# 절대 브라우저에 노출하지 마세요!
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─────────────────────────────────────────────────────
# 선택사항: 다른 환경 변수
# ─────────────────────────────────────────────────────

# 관리자 인증 토큰
ADMIN_TOKEN=wishes2026
