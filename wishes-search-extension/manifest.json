{
  "manifest_version": 3,
  "name": "WISHES 매물검색",
  "version": "1.0.0",
  "description": "WISHES 부동산 매물 검색 확장 프로그램 - wishes.co.kr 관리자 페이지에서 매물을 검색하고 필터링합니다.",
  "permissions": ["storage"],
  "host_permissions": ["https://wishes.co.kr/*"],
  "content_scripts": [
    {
      "matches": ["https://wishes.co.kr/admin*"],
      "css": ["styles.css"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["map-main.js", "page-auth.js"],
      "matches": ["https://wishes.co.kr/*"]
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
