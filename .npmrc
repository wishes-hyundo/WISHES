# Force install optional deps + platform-specific binaries
# 2026 BoB — sharp linux-x64 binary 강제 설치 (Vercel 빌드 환경)
include=optional
prefer-offline=false
audit=false
fund=false

# sharp binaries — npm 이 platform 에 맞는 것만 설치하지만, 명시적으로 설정
sharp_binary_host=https://github.com/lovell/sharp-libvips/releases/download
