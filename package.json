{
  "name": "wishes-v2",
  "version": "2.0.0",
  "private": true,
  "description": "위시스부동산중개법인 기업 웹사이트 v2 - Next.js + Drizzle + Kakao Maps",
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/verify-utf8.js",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "verify-utf8": "node scripts/verify-utf8.js",
    "verify": "npm run verify-utf8 && npm run typecheck && npm run lint",
    "analyze": "ANALYZE=true next build",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed.ts",
    "geocode": "tsx scripts/geocode-listings.ts",
    "oracle": "tsx scripts/sql-oracle.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "dom-snapshot": "playwright test",
    "dom-snapshot:update": "playwright test --update-snapshots",
    "dom-snapshot:report": "playwright show-report",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
