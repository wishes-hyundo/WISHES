    "vitest": "^4.1.5",
    "@types/qrcode": "^1.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "msw": "^2.6.0",
    "yaml": "^2.6.0",
    "@playwright/test": "^1.49.0",
    "@axe-core/playwright": "^4.10.2"
  },
  "overrides": {
    "fast-xml-parser": "^5.7.0",
    "esbuild": "^0.25.0",
    "postcss": "^8.5.10"
  }
