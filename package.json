    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.55.0",
    "resend": "^4.0.0",
    "sharp": "^0.34.5",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.24.0",
    "zustand": "^5.0.2",
    "qrcode": "^1.5.4",
    "@react-pdf/renderer": "^4.1.6"
