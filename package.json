{
  "name": "wishes-v2",
  "version": "2.0.0",
  "private": true,
  "description": "위시스부동산중개법인 기업 웹사이트 v2 - Next.js + Drizzle + Kakao Maps",
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/verify-utf8.js",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "verify-utf8": "node scripts/verify-utf8.js",
    "verify": "npm run verify-utf8 && npm run typecheck && npm run lint",
    "analyze": "ANALYZE=true next build",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed.ts",
    "geocode": "tsx scripts/geocode-listings.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@deck.gl/aggregation-layers": "^9.3.1",
    "@deck.gl/core": "^9.3.1",
    "@deck.gl/geo-layers": "^9.3.1",
    "@deck.gl/layers": "^9.3.1",
    "@deck.gl/mapbox": "^9.3.1",
    "@sentry/nextjs": "^8.47.0",
    "@supabase/supabase-js": "^2.45.0",
    "@tanstack/query-sync-storage-persister": "^5.99.2",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-query-persist-client": "^5.99.2",
    "@tanstack/react-virtual": "^3.13.24",
    "@turf/turf": "^7.1.0",
    "@vladmandic/face-api": "^1.7.14",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.0",
    "date-fns": "^4.1.0",
    "deck.gl": "^9.3.1",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^11.15.0",
    "h3-js": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.475.0",
    "maplibre-gl": "^4.7.1",
    "next": "^15.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.3.0",
    "resend": "^4.0.0",
    "sharp": "^0.33.0",
    "tesseract.js": "^5.1.0",
    "zod": "^3.24.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.0.0",
    "@next/bundle-analyzer": "^15.5.15",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.2.0",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.5"
  }
}
